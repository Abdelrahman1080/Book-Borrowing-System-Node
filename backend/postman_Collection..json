{
  "info": {
    "name": "Node Book System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "http://localhost:3000/api/register", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user1@example.com\",\n    \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "http://localhost:3000/api/login", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user1@example.com\",\n    \"password\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/books", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api","books"] },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"My First Book\"\n}"
            }
          }
        },
        {
          "name": "Get My Books",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/books/me", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api","books","me"] }
          }
        },
        {
          "name": "Archive Book",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/books/{{bookId}}/archive", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api","books","{{bookId}}","archive"] }
          }
        },
        {
          "name": "Unarchive Book",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/books/{{bookId}}/unarchive", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api","books","{{bookId}}","unarchive"] }
          }
        }
      ]
    },
    {
      "name": "Borrow",
      "item": [
        {
          "name": "Borrow Book",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/borrow/{{bookId}}", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api","borrow","{{bookId}}"] }
          }
        },
        {
          "name": "Return Book",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/return/{{bookId}}", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api","return","{{bookId}}"] }
          }
        },
        {
          "name": "My Borrows",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/borrows/me", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api","borrows","me"] }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "token", "value": "" },
    { "key": "bookId", "value": "" }
  ]
}